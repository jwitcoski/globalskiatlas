{
    "name": "global-ski-atlas",
    "version": "1.1.0",
    "description": "Global Ski Atlas — interactive ski resort maps, data, and wiki",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "start:tailwind": "cross-env NODE_ENV=development tailwindcss --postcss -i css/tailwind.css -o css/tailwind-runtime.css -w",
        "build:tailwind": "cross-env NODE_ENV=production tailwindcss --postcss -i css/tailwind.css -o css/tailwind-build.css --minify",
        "wiki:create-tables": "node scripts/wiki-create-tables.js",
        "wiki:ingest": "node scripts/wiki-ingest-parquet.js",
        "serve:static": "serve -l tcp://localhost:3010",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [
        "landing",
        "pages",
        "motion",
        "design",
        "websites"
    ],
    "author": "Paul",
    "license": "MIT",
    "devDependencies": {
        "cross-env": "^10.1.0",
        "serve": "^14.2.4",
        "tailwindcss": "^3.4.1"
    },
    "dependencies": {
        "@aws-sdk/client-dynamodb": "^3.700.0",
        "@aws-sdk/lib-dynamodb": "^3.700.0",
        "diff": "^5.2.0",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "jwks-rsa": "^3.1.0",
        "postcss": "^8.4.33",
        "postcss-simple-vars": "^7.0.1",
        "showdown": "^2.1.0"
    },
    "devDependencies": {
        "cross-env": "^10.1.0",
        "hyparquet": "^1.0.0",
        "serve": "^14.2.4",
        "tailwindcss": "^3.4.1"
    }
}
