# Copy to .env and fill in values. Never commit .env.

# Server port (default 3000)
PORT=3000

# AWS / DynamoDB — set DYNAMODB_TABLE_PREFIX to enable DynamoDB (e.g. "atlas")
# Without this, the wiki uses an in-memory store (data lost on restart).
AWS_REGION=us-east-1
DYNAMODB_TABLE_PREFIX=atlas
# AWS_ACCESS_KEY_ID=     # only needed if not using instance role / SSO
# AWS_SECRET_ACCESS_KEY=

# Cognito (optional — disabling auth allows anonymous wiki editing)
# Same values go in project.local.properties (cognito.* keys) if you prefer that format.
COGNITO_USER_POOL_ID=
COGNITO_REGION=us-east-1
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=
